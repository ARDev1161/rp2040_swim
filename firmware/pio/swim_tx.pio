; Placeholder PIO backend for deterministic SWIM transmission.
; The C bit-bang backend is active in this MVP. This program is kept as the
; intended replacement point for calibrated pulse generation.
.program swim_tx
pull block
out x, 1
jmp !x zero
one:
set pindirs, 1 [1]
set pins, 0 [1]
set pindirs, 0 [19]
jmp next
zero:
set pindirs, 1 [19]
set pins, 0 [1]
set pindirs, 0 [1]
next:
nop
